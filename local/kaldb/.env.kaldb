# Local overrides for running the OpenTelemetry Demo alongside a local KalDB stack.
# KalDB uses host port 8080 for astra_index, so move the demo frontend proxy.
ENVOY_PORT=18080
FRONTEND_PROXY_ADDR=frontend-proxy:18080
LOCUST_HOST=http://frontend-proxy:18080
PUBLIC_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:18080/otlp-http/v1/traces
