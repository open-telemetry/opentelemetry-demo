              { "color": "red", "value": null },
              { "color": "orange", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "unit": "percent",
          "min": 95,
          "max": 100
        }
      },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
